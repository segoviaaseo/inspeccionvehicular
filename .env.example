# Supabase (Required for both development and production)
VITE_SUPABASE_URL=https://xuukzgykxmqrcrvpdzas.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Database - Direct connection from server
# Get this from Supabase: Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres.xuukzgykxmqrcrvpdzas:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Session secret (auto-generated in production)
SESSION_SECRET=your-secret-key-here

# Server
PORT=5000
NODE_ENV=development

# Google Drive backup (optional, for automatic PDF backups of completed inspections)
# Paste the entire JSON of the Service Account key. The app will create an
# "INSPECCIONES" folder with subfolders per month (e.g. "Julio 2026") and
# save each completed inspection's PDF there. See GOOGLE-DRIVE-SETUP.md.
# GOOGLE_DRIVE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}

# Netlify-specific (set these in Netlify UI)
# VITE_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY
# DATABASE_URL
